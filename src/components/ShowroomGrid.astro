---
// ShowroomGrid.astro - Static data version
const products = [
  {
    title: 'XAU Scalper Pro',
    slug: 'xau-scalper-pro',
    description: 'Sistema de trading automatizado para XAU/USD con estrategias EMA/RSI/ATR',
    image: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a0?w=600&auto=format&fit=crop',
    price: 299,
    category: 'Trading Bots',
  },
  {
    title: 'Sports Analytics',
    slug: 'sports-analytics',
    description: 'Plataforma de análisis para MLB, NBA y NHL con datos en tiempo real',
    image: 'https://images.unsplash.com/photo-1569517282132-2742a3616a0c?w=600&auto=format&fit=crop',
    price: 199,
    category: 'Dashboards',
  },
  {
    title: 'Crypto Dashboard',
    slug: 'crypto-dashboard',
    description: 'Dashboard en tiempo real para seguimiento de cryptomonedas y alertas',
    image: 'https://images.unsplash.com/photo-1620321023374-d1a68fbc720d?w=600&auto=format&fit=crop',
    price: 149,
    category: 'Dashboards',
  },
  {
    title: 'API Wrapper',
    slug: 'api-wrapper',
    description: 'Wrapper unificado para APIs deportivas (ESPN, NHL, MLB)',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&auto=format&fit=crop',
    price: 99,
    category: 'APIs',
  },
];

const categories = ['Todos', 'Trading Bots', 'Dashboards', 'APIs'];
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="showroom-grid">
  <!-- Filter tabs -->
  <div class="col-span-full flex flex-wrap justify-center gap-2 mb-8">
    {categories.map((cat, i) => (
      <button 
        class={`btn btn-sm ${i === 0 ? 'bg-accent text-steel-900' : 'btn-outline border-steel-500 text-chrome'} filter-btn`}
        data-category={cat}
      >
        {cat}
      </button>
    ))}
  </div>
  
  {products.map((product) => (
    <div class="card-industrial group cursor-pointer" data-category={product.category}>
      {product.image && (
        <figure class="aspect-square overflow-hidden relative">
          <img 
            src={product.image} 
            alt={product.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-steel-900/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="absolute bottom-4 left-4 right-4">
              <a 
                href={`#contacto?product=${product.slug}`}
                class="btn btn-sm bg-accent text-steel-900 w-full font-semibold"
              >
                Consultar
              </a>
            </div>
          </div>
        </figure>
      )}
      <div class="p-4">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-lg font-display font-semibold text-chrome">
            {product.title}
          </h3>
          {product.price && (
            <span class="text-accent font-bold font-mono">
              ${product.price}
            </span>
          )}
        </div>
        
        <p class="text-chrome/70 text-sm mb-3 line-clamp-2">
          {product.description}
        </p>
        
        <span class="badge badge-sm bg-steel-700 text-chrome border-none">
          {product.category}
        </span>
      </div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('.filter-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = (btn as HTMLElement).dataset.category;
      
      // Update active button
      document.querySelectorAll('.filter-btn').forEach((b) => {
        b.classList.remove('bg-accent', 'text-steel-900');
        b.classList.add('btn-outline', 'border-steel-500', 'text-chrome');
      });
      btn.classList.add('bg-accent', 'text-steel-900');
      btn.classList.remove('btn-outline', 'border-steel-500', 'text-chrome');
      
      // Filter products
      document.querySelectorAll('#showroom-grid .card-industrial[data-category]').forEach((card) => {
        const cardCategory = (card as HTMLElement).dataset.category;
        if (category === 'Todos' || cardCategory === category) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>