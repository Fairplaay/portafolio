---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export interface ExperienceItem {
  position: string;
  company: string;
  duration: string;
  responsibilities: string[];
  positionEs: string;
  responsibilitiesEs: string[];
}

interface Props extends ExperienceItem {}

const { position, company, duration, responsibilities, positionEs, responsibilitiesEs } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const displayPosition = lang === 'en' ? position : positionEs;
const displayResponsibilities = lang === 'en' ? responsibilities : responsibilitiesEs;
---

<h3>
  {displayPosition} {t('experience.at')} {company}
</h3>
<span class="timeline-date">{duration}</span>
<div>
  {
    displayResponsibilities.map((p) => {
      return <p>{p}</p>;
    })
  }
</div>

<style>
  h3 {
    margin: 0;
    font-size: 1.2em;
    color: var(--primary-color);
  }
  .timeline-date {
    display: block;
    font-size: 0.9em;
    color: var(--text-color);
    margin-bottom: 10px;
    opacity: 0.7;
  }
  p {
    margin: 5px 0;
    font-size: 1em;
    color: var(--text-color);
  }
</style>