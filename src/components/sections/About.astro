---
import { socialMediaIcons } from '../../assets/social/util';
import { aboutMe } from '../../data/content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const aboutData = aboutMe[lang];
---

<section id="about">
  <h2>{t('about.title')}</h2>
  <article>
    <div class="about-profile">
      <picture>
        <img
          src={aboutData.profile.picture}
          alt={aboutData.profile.altText}
          loading="lazy"
          width="200"
          height="200"
        />
      </picture>
      <div class="social-media">
        {
          Object.entries(aboutData.socialMedia).map(([key, value]) => {
            const IconComponent = socialMediaIcons[key as keyof typeof socialMediaIcons];

            return (
              <a href={value} target="_blank" rel="noopener noreferrer">
                <IconComponent width={40} height={40} />
                <span class="sr-only">{key}</span>
              </a>
            );
          })
        }
      </div>
    </div>
     <div class="about-content">
       <h3>{aboutData.name}</h3>
       <p>{t('about.bio1')}</p>
       <p>{t('about.bio2')}</p>
       <p>{t('about.bio3')}</p>
       <div class="hobbies">
         {aboutData.hobbies.map((hobby) => (
           <span class="hobby-tag">{hobby}</span>
         ))}
      </div>
    </div>
  </article>
</section>

<style>
  section#about {
    width: 100%;
    padding: 20px;
  }
  section#about h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--primary-color);
  }
  section#about article {
    border-radius: 15px;
    background-color: var(--primary-color-dark);
    display: flex;
    gap: 29px;
    padding: 20px;
    max-width: 800px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    section#about article {
      flex-wrap: wrap;
      flex-direction: column;
      align-items: center;
    }
  }

  .about-profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 10px;
  }
  .about-profile picture {
    overflow: hidden;
    max-width: 200px;
    height: auto;
    border: 3px solid var(--primary-color);
    border-radius: 30px;
  }
  .about-profile a {
    color: #fff;
    transition: color 0.3s ease;
  }
  .about-profile a:hover {
    color: var(--primary-color);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }
  .about-content h3 {
    color: var(--primary-color);
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .about-content p {
    color: #f2f2f2;
    line-height: 1.6;
  }

  .hobbies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(219, 196, 4, 0.2);
  }

  .hobby-tag {
    background: rgba(219, 196, 4, 0.15);
    color: var(--primary-color);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid rgba(219, 196, 4, 0.3);
    transition: all 0.2s ease;
  }
  .hobby-tag:hover {
    background: rgba(219, 196, 4, 0.25);
  }

  span.sr-only {
    position: absolute;
    right: -20px;
    bottom: -16px;
    opacity: 0;
  }

  .social-media {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }
</style>