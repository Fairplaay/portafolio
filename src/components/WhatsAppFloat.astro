---
// WhatsApp Float Component
interface Props {
  telefono?: string;
  mensaje?: string;
  position?: 'bottom-left' | 'bottom-right';
}

const { telefono = '+584242532335', mensaje = 'Hola Jesus, me想去ía cotizar tus servicios', position = 'bottom-right' } = Astro.props;

const waUrl = `https://wa.me/${telefono.replace(/\D/g, '')}?text=${encodeURIComponent(mensaje)}`;

const positions = {
  'bottom-left': 'left-4',
  'bottom-right': 'right-4',
};
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`fixed ${positions[position]} bottom-6 z-50 btn btn-primary btn-circle shadow-lg hover:scale-110 transition-transform duration-200`}
  aria-label="Contactar por WhatsApp"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.584 0 1.568 1.155 2.975 1.317 3.185.149.198 2.096 3.355 5.076 4.707.928.43 1.644.686 2.003.878.448.241 1.136.207 1.576.103.297-.074 1.687-.651 2.016-1.285.321-.632.321-1.175.321-1.225.008-.173-.025-.397-.099-.572z"/>
  </svg>
</a>