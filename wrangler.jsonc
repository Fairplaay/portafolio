{
  "name": "portafolio-jesus-garcia",
  "compatibility_date": "2024-12-18",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",
  "env": {
    "PUBLIC_SANITY_PROJECT_ID": {
      "type": "string"
    },
    "PUBLIC_SANITY_DATASET": {
      "type": "string",
      "default": "production"
    }
  }
}